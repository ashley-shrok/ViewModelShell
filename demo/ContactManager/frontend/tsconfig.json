{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "viewmodel-shell": ["../../../viewmodel-shell/src/index.ts"],
      "viewmodel-shell/browser": ["../../../viewmodel-shell/src/browser.ts"]
    }
  },
  "include": ["src"]
}
