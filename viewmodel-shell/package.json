{
  "name": "@ashley-shrok/viewmodel-shell",
  "version": "0.13.0",
  "description": "A server-driven UI framework where the wire format is structured enough that agents can build full-stack apps without ever opening a browser and all UI tests are pure unit tests with no browser runtime. Server returns a JSON tree of typed nodes; a thin TypeScript adapter renders it to DOM. Backend-agnostic — a .NET reference backend ships with the repo, but any language can produce the JSON contract.",
  "type": "module",
  "license": "MIT",
  "author": "ashley-shrok",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashley-shrok/ViewModelShell.git"
  },
  "homepage": "https://github.com/ashley-shrok/ViewModelShell#readme",
  "bugs": "https://github.com/ashley-shrok/ViewModelShell/issues",
  "keywords": [
    "viewmodel",
    "server-driven-ui",
    "sdui",
    "framework",
    "typescript"
  ],
  "files": [
    "dist",
    "styles",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "vms-tui": "./dist/tui-cli.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.tui.json",
    "check:core-globals": "node scripts/check-core-platform-globals.mjs",
    "check:aa-contrast": "node scripts/check-aa-contrast.mjs",
    "check:no-demo-style": "node scripts/check-no-demo-style.mjs",
    "check:theme-byte-identity": "node scripts/check-theme-byte-identity.mjs",
    "check:theme-function": "node scripts/check-theme-function.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@opentui/core": "^0.2.14",
    "@opentui/react": "^0.2.14",
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.4"
  },
  "optionalDependencies": {
    "@opentui/core": "^0.2.14",
    "@opentui/react": "^0.2.14",
    "react": "^19.2.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "default": "./dist/tui.js"
    },
    "./styles.css": "./styles/default.css",
    "./themes/dark-blue.css": "./styles/themes/dark-blue.css",
    "./themes/dark-green.css": "./styles/themes/dark-green.css",
    "./themes/dark-rose.css": "./styles/themes/dark-rose.css",
    "./themes/dark-amber.css": "./styles/themes/dark-amber.css",
    "./themes/dark-teal.css": "./styles/themes/dark-teal.css",
    "./themes/dark-purple.css": "./styles/themes/dark-purple.css",
    "./themes/light-purple.css": "./styles/themes/light-purple.css",
    "./themes/light-blue.css": "./styles/themes/light-blue.css",
    "./themes/light-green.css": "./styles/themes/light-green.css",
    "./themes/light-rose.css": "./styles/themes/light-rose.css",
    "./themes/light-amber.css": "./styles/themes/light-amber.css",
    "./themes/light-teal.css": "./styles/themes/light-teal.css"
  }
}
