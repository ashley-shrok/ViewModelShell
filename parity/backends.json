{
  "$schema-comment": "Each backend implements the same demos. The harness runs prebuilds serially (so .NET demos sharing a library don't fight over MSBuild locks), then spins up every backend in parallel, runs the fixture script against each, and diffs responses.",
  "backends": [
    {
      "name": "dotnet-tasks",
      "cwd": "../demo/Tasks/AspNetCore",
      "prebuild": { "cmd": "dotnet", "args": ["build", "--nologo", "-v", "minimal"] },
      "start": "dotnet",
      "args": ["run", "--no-build", "--no-launch-profile", "--urls", "http://localhost:5001"],
      "baseUrl": "http://localhost:5001",
      "ready": "/api/tasks",
      "fixtures": ["tasks"]
    },
    {
      "name": "bun-tasks",
      "cwd": "../demo/Tasks-bun",
      "start": "bun",
      "args": ["run", "server.ts"],
      "env": { "PORT": "5002" },
      "baseUrl": "http://localhost:5002",
      "ready": "/api/tasks",
      "fixtures": ["tasks"]
    },
    {
      "name": "dotnet-contacts",
      "cwd": "../demo/ContactManager/AspNetCore",
      "prebuild": { "cmd": "dotnet", "args": ["build", "--nologo", "-v", "minimal"] },
      "start": "dotnet",
      "args": ["run", "--no-build", "--no-launch-profile", "--urls", "http://localhost:5003"],
      "baseUrl": "http://localhost:5003",
      "ready": "/api/contacts",
      "fixtures": ["contacts"]
    },
    {
      "name": "bun-contacts",
      "cwd": "../demo/ContactManager-bun",
      "start": "bun",
      "args": ["run", "server.ts"],
      "env": { "PORT": "5004" },
      "baseUrl": "http://localhost:5004",
      "ready": "/api/contacts",
      "fixtures": ["contacts"]
    },
    {
      "name": "dotnet-retro",
      "cwd": "../demo/RetroBoard/AspNetCore",
      "prebuild": { "cmd": "dotnet", "args": ["build", "--nologo", "-v", "minimal"] },
      "start": "dotnet",
      "args": ["run", "--no-build", "--no-launch-profile", "--urls", "http://localhost:5005"],
      "baseUrl": "http://localhost:5005",
      "ready": "/api/retro",
      "fixtures": ["retro"]
    },
    {
      "name": "bun-retro",
      "cwd": "../demo/RetroBoard-bun",
      "start": "bun",
      "args": ["run", "server.ts"],
      "env": { "PORT": "5006" },
      "baseUrl": "http://localhost:5006",
      "ready": "/api/retro",
      "fixtures": ["retro"]
    },
    {
      "name": "dotnet-expenses",
      "cwd": "../demo/ExpenseTracker/AspNetCore",
      "prebuild": { "cmd": "dotnet", "args": ["build", "--nologo", "-v", "minimal"] },
      "start": "dotnet",
      "args": ["run", "--no-build", "--no-launch-profile", "--urls", "http://localhost:5007"],
      "baseUrl": "http://localhost:5007",
      "ready": "/api/expenses",
      "fixtures": ["expenses"]
    },
    {
      "name": "bun-expenses",
      "cwd": "../demo/ExpenseTracker-bun",
      "start": "bun",
      "args": ["run", "server.ts"],
      "env": { "PORT": "5008" },
      "baseUrl": "http://localhost:5008",
      "ready": "/api/expenses",
      "fixtures": ["expenses"]
    },
    {
      "name": "dotnet-helpdesk",
      "cwd": "../demo/HelpDesk/AspNetCore",
      "prebuild": { "cmd": "dotnet", "args": ["build", "--nologo", "-v", "minimal"] },
      "cleanupFiles": ["helpdesk-parity-dotnet.db"],
      "start": "dotnet",
      "args": ["run", "--no-build", "--no-launch-profile", "--urls", "http://localhost:5009"],
      "env": { "HELPDESK_DB": "helpdesk-parity-dotnet.db" },
      "baseUrl": "http://localhost:5009",
      "ready": "/api/requester",
      "fixtures": ["helpdesk"]
    },
    {
      "name": "bun-helpdesk",
      "cwd": "../demo/HelpDesk-bun",
      "cleanupFiles": ["helpdesk-parity-bun.db"],
      "start": "bun",
      "args": ["run", "server.ts"],
      "env": { "PORT": "5010", "HELPDESK_DB": "helpdesk-parity-bun.db" },
      "baseUrl": "http://localhost:5010",
      "ready": "/api/requester",
      "fixtures": ["helpdesk"]
    },
    {
      "name": "dotnet-probe",
      "cwd": "../demo/FeatureProbe/AspNetCore",
      "prebuild": { "cmd": "dotnet", "args": ["build", "--nologo", "-v", "minimal"] },
      "start": "dotnet",
      "args": ["run", "--no-build", "--no-launch-profile", "--urls", "http://localhost:5011"],
      "baseUrl": "http://localhost:5011",
      "ready": "/api/probe",
      "fixtures": ["feature-probe"]
    },
    {
      "name": "bun-probe",
      "cwd": "../demo/FeatureProbe-bun",
      "start": "bun",
      "args": ["run", "server.ts"],
      "env": { "PORT": "5012" },
      "baseUrl": "http://localhost:5012",
      "ready": "/api/probe",
      "fixtures": ["feature-probe"]
    },
    {
      "name": "node-probe",
      "cwd": "../demo/FeatureProbe-bun",
      "start": "node",
      "args": ["--import", "tsx", "server-node.ts"],
      "env": { "PORT": "5013" },
      "baseUrl": "http://localhost:5013",
      "ready": "/api/probe",
      "fixtures": ["feature-probe"]
    }
  ]
}
