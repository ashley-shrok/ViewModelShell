{
  "name": "reorder",
  "endpoint": "/api/reorder",
  "actionEndpoint": "/api/reorder/action",
  "$comment": "Phase 6 wire shape: _action carries {name} only. Per-item move actions encode the id in the action name (move-start-${id} / move-before-${id}). No bind paths in this demo — no input fields.",
  "steps": [
    { "id": "initial",        "method": "GET" },
    { "id": "pick-a",         "method": "POST", "action": { "name": "move-start-a" } },
    { "id": "a-before-d",     "method": "POST", "action": { "name": "move-before-d" } },
    { "id": "pick-e",         "method": "POST", "action": { "name": "move-start-e" } },
    { "id": "e-before-b",     "method": "POST", "action": { "name": "move-before-b" } },
    { "id": "pick-c",         "method": "POST", "action": { "name": "move-start-c" } },
    { "id": "c-to-end",       "method": "POST", "action": { "name": "move-to-end" } },
    { "id": "pick-b",         "method": "POST", "action": { "name": "move-start-b" } },
    { "id": "cancel",         "method": "POST", "action": { "name": "move-cancel" } },
    { "id": "pick-d",         "method": "POST", "action": { "name": "move-start-d" } },
    { "id": "d-before-self",  "method": "POST", "action": { "name": "move-before-d" } }
  ]
}
