{
  "name": "feature-probe",
  "endpoint": "/api/probe",
  "actionEndpoint": "/api/probe/action",
  "$comment": "Exercises framework wire surfaces no demo app uses naturally: redirect, side effects, polling cadence, file upload via multipart.",
  "steps": [
    { "id": "initial",          "method": "GET" },

    { "id": "redirect-default", "method": "POST", "action": { "name": "trigger-redirect" } },
    { "id": "fresh-after-redirect", "method": "GET", "freshState": true },
    { "id": "redirect-custom",  "method": "POST", "action": { "name": "trigger-redirect", "context": { "to": "/custom-target" } } },

    { "id": "fresh-1",          "method": "GET", "freshState": true },
    { "id": "set-storage-default", "method": "POST", "action": { "name": "set-storage" } },
    { "id": "set-storage-custom",  "method": "POST", "action": { "name": "set-storage", "context": { "local-value": "L1", "session-value": "S1" } } },

    { "id": "fresh-download",   "method": "GET", "freshState": true },
    { "id": "download-default", "method": "POST", "action": { "name": "trigger-download" } },
    { "id": "download-custom",  "method": "POST", "action": { "name": "trigger-download", "context": { "url": "/api/probe/file/report.pdf", "filename": "report.pdf" } } },

    { "id": "fresh-2",          "method": "GET", "freshState": true },
    { "id": "poll-1",           "method": "POST", "action": { "name": "do-poll" } },
    { "id": "poll-2",           "method": "POST", "action": { "name": "do-poll" } },
    { "id": "poll-3",           "method": "POST", "action": { "name": "do-poll" } },

    { "id": "fresh-3",          "method": "GET", "freshState": true },
    {
      "id": "upload-small",
      "method": "POST",
      "action": { "name": "upload" },
      "attach": { "attachment": { "name": "hello.txt", "content": "hello world" } }
    },
    {
      "id": "upload-replace",
      "method": "POST",
      "action": { "name": "upload" },
      "attach": { "attachment": { "name": "second.txt", "content": "second upload contents" } }
    },
    { "id": "copy-button-node", "method": "POST", "action": { "name": "show-copy-button" } },

    { "id": "fresh-multiaction", "method": "GET", "freshState": true },
    { "id": "form-save-draft",   "method": "POST", "action": { "name": "save-draft", "context": { "note": "hello" } } },
    { "id": "form-publish",      "method": "POST", "action": { "name": "publish",    "context": { "note": "shipit" } } },

    { "id": "fresh-long",        "method": "GET",  "freshState": true },
    { "id": "long-start",        "method": "POST", "action": { "name": "start-long-action" } },
    { "id": "long-poll-1",       "method": "POST", "action": { "name": "long-action-poll" } },
    { "id": "long-poll-2",       "method": "POST", "action": { "name": "long-action-poll" } },
    { "id": "long-poll-3",       "method": "POST", "action": { "name": "long-action-poll" } },

    { "id": "fresh-table",       "method": "GET", "freshState": true },
    { "id": "tbl-select-1",      "method": "POST", "action": { "name": "table-select", "context": { "id": "1", "checked": true } } },
    { "id": "tbl-select-2",      "method": "POST", "action": { "name": "table-select", "context": { "id": "2", "checked": true } } },
    { "id": "tbl-page-2",        "method": "POST", "action": { "name": "table-page",   "context": { "page": 2 } } },
    { "id": "tbl-select-5",      "method": "POST", "action": { "name": "table-select", "context": { "id": "5", "checked": true } } },
    { "id": "tbl-select-all-p2", "method": "POST", "action": { "name": "table-select", "context": { "all": true, "checked": true } } },
    { "id": "tbl-deselect-2",    "method": "POST", "action": { "name": "table-select", "context": { "id": "2", "checked": false } } },
    { "id": "tbl-sort-name-asc", "method": "POST", "action": { "name": "table-sort",   "context": { "column": "name", "direction": "asc" } } },
    { "id": "tbl-sort-name-desc","method": "POST", "action": { "name": "table-sort",   "context": { "column": "name", "direction": "desc" } } },
    { "id": "tbl-sort-status",   "method": "POST", "action": { "name": "table-sort",   "context": { "column": "status", "direction": "asc" } } },
    { "id": "tbl-filter-e",      "method": "POST", "action": { "name": "table-filter", "context": { "value": "e" } } },
    { "id": "tbl-page-2-filtered","method": "POST", "action": { "name": "table-page",  "context": { "page": 2 } } },
    { "id": "tbl-clear-page",    "method": "POST", "action": { "name": "table-select", "context": { "all": true, "checked": false } } },
    { "id": "tbl-filter-clear",  "method": "POST", "action": { "name": "table-filter", "context": { "value": "" } } }
  ]
}
