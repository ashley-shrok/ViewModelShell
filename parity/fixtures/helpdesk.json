{
  "name": "helpdesk",
  "endpoint": "/api/requester",
  "actionEndpoint": "/api/requester/action",
  "$comment": "Phase 6 wire shape: _action carries {name} only. Cross-controller fixture (Requester creates tickets; Agent acts on them via shared SQLite DB). The wire shape change moved every form-input value into a state slot — fixture steps that simulate a 'user typed → user clicked' interaction set those slots via stateMutations. Per-tab actions (filter-${value}, set-type-${value}, set-priority-${value}) carry the value in the action name AND the TabsNode bind writes it to state; the agent's filter handler is a pure no-op (bind alone is enough) while the requester's set-type handler clears validationError as a side effect. Per-row select-ticket-${id} reads the id from the action name; singular page-level actions (start-ticket / resolve-ticket / save-notes) read state.selectedTicketId. Bulk actions read state.selectedIds — fixture writes selection via stateMutations before each bulk dispatch.",
  "steps": [
    { "id": "req-initial",          "method": "GET" },
    { "id": "req-start-create",     "method": "POST", "action": { "name": "start-create" } },
    { "id": "req-set-type-software","method": "POST", "action": { "name": "set-type-software" }, "stateMutations": [{ "path": "createType", "value": "software" }] },
    { "id": "req-set-priority-high","method": "POST", "action": { "name": "set-priority-high" }, "stateMutations": [{ "path": "createPriority", "value": "high" }] },
    { "id": "req-validation-empty", "method": "POST", "action": { "name": "create-ticket" } },
    { "id": "req-create-1",         "method": "POST", "action": { "name": "create-ticket" }, "stateMutations": [
      { "path": "draftTitle",       "value": "Outlook keeps crashing" },
      { "path": "draftApplication", "value": "Microsoft Outlook" },
      { "path": "draftDescription", "value": "Crashes when opening mailbox." }
    ] },
    { "id": "req-start-create-2",   "method": "POST", "action": { "name": "start-create" } },
    { "id": "req-set-type-hw",      "method": "POST", "action": { "name": "set-type-hardware" }, "stateMutations": [{ "path": "createType", "value": "hardware" }] },
    { "id": "req-create-2",         "method": "POST", "action": { "name": "create-ticket" }, "stateMutations": [
      { "path": "draftTitle",       "value": "Laptop won't charge" },
      { "path": "draftDeviceModel", "value": "Dell XPS 15" }
    ] },

    { "id": "agt-initial",          "method": "GET",  "endpoint": "/api/agent",  "freshState": true },
    { "id": "agt-filter-open",      "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "filter-open" }, "stateMutations": [{ "path": "filter", "value": "open" }] },
    { "id": "agt-filter-all",       "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "filter-all" },  "stateMutations": [{ "path": "filter", "value": "all" }] },
    { "id": "agt-select-1",         "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "select-ticket-1" } },
    { "id": "agt-start-1",          "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "start-ticket" } },
    { "id": "agt-save-notes",       "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "save-notes" },     "stateMutations": [{ "path": "agentNotes", "value": "Investigating PST corruption." }] },
    { "id": "agt-resolve-1",        "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "resolve-ticket" } },
    { "id": "agt-back",             "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "back-to-queue" } },

    { "id": "agt-filter-title",     "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "filter-text" }, "stateMutations": [{ "path": "titleFilter", "value": "outlook" }] },
    { "id": "agt-filter-title-clear","method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "filter-text" }, "stateMutations": [{ "path": "titleFilter", "value": "" }] },
    { "id": "agt-bulk-reopen-1-2",  "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "bulk-reopen" },  "stateMutations": [{ "path": "selectedIds.1", "value": true }, { "path": "selectedIds.2", "value": true }] },
    { "id": "agt-bulk-start-1",     "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "bulk-start" },   "stateMutations": [{ "path": "selectedIds.1", "value": true }] },
    { "id": "agt-bulk-resolve-2",   "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "bulk-resolve" }, "stateMutations": [{ "path": "selectedIds.2", "value": true }] },

    { "id": "agt-filter-resolved",  "method": "POST", "actionEndpoint": "/api/agent/action", "action": { "name": "filter-resolved" }, "stateMutations": [{ "path": "filter", "value": "resolved" }] },

    { "id": "req-back-to-list",     "method": "GET",  "freshState": true },
    { "id": "req-view-1",           "method": "POST", "action": { "name": "select-ticket-1" } },
    { "id": "req-back",             "method": "POST", "action": { "name": "back-to-list" } }
  ]
}
