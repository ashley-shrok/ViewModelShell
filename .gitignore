# .NET build output
bin/
obj/

# Node
node_modules/
dist/
*.tsbuildinfo

# Vite build output (regenerated by MSBuild's BuildFrontend target on every dotnet build)
demo/*/AspNetCore/wwwroot/

# IDE
.vs/
*.user

# NuGet pack output — build artifacts, never commit
viewmodel-shell-dotnet/nupkg/

# Secrets / auth — NEVER commit
.npmrc
.env
.env.*

# SQLite DBs created at runtime by demos / parity runs.
# Globbed, not enumerated: these were listed one-by-one, so adding the seeded
# parity twins (helpdesk-parity-*-seeded.db) silently produced committable
# artifacts. A new parity backend must not be able to reintroduce that.
demo/HelpDesk/AspNetCore/helpdesk.db
demo/HelpDesk/AspNetCore/helpdesk-parity-*.db
demo/HelpDesk-bun/helpdesk.db
demo/HelpDesk-bun/helpdesk-parity-*.db

# GSD auto-generated state scratch — AGENTS.md forbids a committed state ledger
.planning/STATE.md
