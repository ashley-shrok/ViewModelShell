*.user

# NuGet pack output — build artifacts, never commit
viewmodel-shell-dotnet/nupkg/

# Secrets / auth — NEVER commit
.npmrc
.env
.env.*

# SQLite DBs created at runtime by demos / parity runs
demo/HelpDesk/AspNetCore/helpdesk.db
demo/HelpDesk/AspNetCore/helpdesk-parity-dotnet.db
demo/HelpDesk-bun/helpdesk.db
demo/HelpDesk-bun/helpdesk-parity-bun.db
